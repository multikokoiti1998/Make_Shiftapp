<Window
    x:Class="Shiftapp_demo.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Shiftapp_demo"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:Shiftapp_demo.ViewModels" 
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
    mc:Ignorable="d"
    Title="MainWindow"
    WindowState="Maximized"
    MinHeight="600" MinWidth="800">


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MaxWidth="550"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Margin="10">
            <Calendar x:Name="ShiftCalendar"
                      FontSize="24"
                      Style="{DynamicResource MaterialDesignCalendarPortrait}"
                      CalendarDayButtonStyle="{DynamicResource MaterialDesignFlatButton}"
                      DisplayDateChanged="ShiftCalendar_DisplayDateChanged"
                      SelectionMode="MultipleRange">
            </Calendar>

            <Button Content="シフト作成" Height="70" FontSize="20" Margin="0,15,0,0" Command="{Binding GenerateShiftCommand}"/>

            <Button Content="管理者画面"  Command="{Binding OpenAdminCommand}" Height="70" FontSize="20" Margin="0,15,0,0"/>

            <StackPanel Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" 
            Orientation="Horizontal"
            Margin="10,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            >

                <!-- CSV出力ボタン -->
                <Button Content="CSV出力"
            Command="{Binding ExportCsvRowsCommand}"
            CommandParameter="{Binding ElementName=ShiftCalendar, Path=DisplayDate}"
            Width="150" Height="70"
            FontSize="18"
            Margin="0,15,15,0"
            Padding="10"
            />

                <!-- シフト修正ボタン -->
                <Button Content="シフト修正"
            Width="150" Height="70"
            FontSize="18"
            Margin="0,15,0,0"
            Padding="10"
            />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Column="1" Grid.Row="0" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
               Background="{DynamicResource MaterialDesignPaper}"  
               Padding="12,10,12,8">
                <TextBlock x:Name="MonthHeaderTextBlock"
               HorizontalAlignment="Left"
               VerticalAlignment="Center"
               FontSize="20"
               FontWeight="Bold"
               Text="{Binding MonthHeaderText}"/>
            </Border>
            
            <DataGrid x:Name="ShiftDataGrid"
              Grid.Row="1"
              Margin="0,6,0,0" 
              FontSize="13"
              AutoGenerateColumns="False"
              ItemsSource="{Binding ShiftDataCollection}"
              IsReadOnly="False"
              ScrollViewer.HorizontalScrollBarVisibility="Auto"
              ScrollViewer.VerticalScrollBarVisibility="Auto"
              GridLinesVisibility="All"
              FrozenColumnCount="2"
              ColumnWidth="*"
              MinColumnWidth="28"
              RowHeight="40"
              ColumnHeaderHeight="40"
              EnableRowVirtualization="True"
              EnableColumnVirtualization="True">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment"   Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Resources>
                    <!-- セルの余白を最小化 -->
                    <Style TargetType="DataGridCell" BasedOn="{x:Null}">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                    </Style>

                    <!-- テキストの余白をゼロに -->
                    <Style TargetType="TextBlock" BasedOn="{x:Null}">
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="TextWrapping" Value="NoWrap"/>
                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        <Setter Property="FontSize" Value="10"/>
                    </Style>

                    <!-- ヘッダーも詰める -->
                    <Style TargetType="DataGridColumnHeader" BasedOn="{x:Null}">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                    </Style>

                </DataGrid.Resources>

            </DataGrid>
        </Grid>
    </Grid>
</Window>